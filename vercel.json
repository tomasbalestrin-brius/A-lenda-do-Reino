{
  "rewrites": [
    {
      "source": "/((?!assets/|favicon.ico|manifest.json|logo192.png|logo512.png|robots.txt|service-worker.js).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/service-worker.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        },
        {
          "key": "Service-Worker-Allowed",
          "value": "/"
        }
      ]
    }
  ]
}
